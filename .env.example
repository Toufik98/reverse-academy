# Reverse Academy — Environment Variables
# Copy to .env and fill in values

# Database (Turso)
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Auth
JWT_SECRET=change-me-to-a-random-string
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@reverse.academy

# Piston (Code execution sidecar)
# Docker: http://piston:2000/api/v2  |  Hetzner: http://[2a01:4f9:c014:8af6::1]:2001/api/v2
PISTON_URL=http://piston:2000/api/v2

# Sentry
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=

# App
PUBLIC_APP_URL=http://localhost:5173
RUST_LOG=info
